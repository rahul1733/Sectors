        const map = L.map('map', { zoomControl: false });
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);

        function getAsmColor(asm) {
            const colors = {
                'Ankit Kumar Jain': '#e91e63', 
                'Banti Singh Kushwah': '#9c27b0',
                'Pankaj Kumar Meena': '#3f51b5', 
                'Parvez Ali': '#00bcd4',
                'Praveen Singh Rathore': '#4caf50', 
                'Rahul Bhatt': '#007bff', 
                'Shyam Soni': '#795548'
            };
            return colors[asm] || '#607d8b';
        }

        function buildPopup(sec) {
            const d = excelData[sec];
            if (!d) return "<b>" + sec + "</b><br>No Data Found";
            return `
                <div style="width:250px; font-size:12px; color:#333; line-height:1.4;">
                    <div style="background:#5f259f; color:white; padding:6px; font-weight:bold; border-radius:4px 4px 0 0; text-align:center;">Sector: ${sec}</div>
                    <div style="padding:10px; border:1px solid #5f259f; border-top:none; background:#fff;">
                        <table style="width:100%; border-collapse:collapse;">
                            <tr><td><b>ASM:</b></td><td align="right">${d.asm}</td></tr>
                            <tr><td><b>MAM:</b></td><td align="right">${d.mam}</td></tr>
                            <tr><td colspan="2"><hr style="border:0; border-top:1px dashed #ccc; margin:5px 0;"></td></tr>
                            <tr><td><b>Agent-1:</b></td><td align="right">${d.a1_name}</td></tr>
                            <tr><td><b>Number:</b></td><td align="right">${d.a1_num}</td></tr>
                            <tr><td><b>Agent-2:</b></td><td align="right">${d.a2_name}</td></tr>
                            <tr><td><b>Number:</b></td><td align="right">${d.a2_num}</td></tr>
                            <tr><td colspan="2"><hr style="border:0; border-top:1px dashed #ccc; margin:5px 0;"></td></tr>
                            <tr><td><b>PhonePe Txn:</b></td><td align="right">${d.pp_txn}</td></tr>
                            <tr><td><b>PhonePe MS:</b></td><td align="right"><span style="font-size:18px; font-weight:bold; color:#5f259f;">${d.pp_ms}</span></td></tr>
                            <tr><td><b>Industry Txn:</b></td><td align="right">${d.ind_txn}</td></tr>
                            <tr><td><b>Paytm MS:</b></td><td align="right">${d.ptm_ms}</td></tr>
                            <tr><td colspan="2"><hr style="border:0; border-top:1px dashed #ccc; margin:5px 0;"></td></tr>
                            <tr><td><b>MSIM Attack:</b></td><td align="right">${d.msim}</td></tr>
                            <tr><td><b>SSD_Re1:</b></td><td align="right">${d.ssd}</td></tr>
                            <tr><td><b>HP Winback:</b></td><td align="right">${d.hp}</td></tr>
                            <tr><td><b>VPA_MSIM:</b></td><td align="right">${d.vpa}</td></tr>
                        </table>
                    </div>
                </div>`;
        }

        const geoLayer = L.geoJSON(geo, {
            style: (f) => {
                const sec = f.properties.name;
                const d = excelData[sec];
                return { fillColor: d ? getAsmColor(d.asm) : '#ccc', color: 'white', weight: 1, fillOpacity: 0.7 };
            },
            onEachFeature: (f, l) => {
                const name = f.properties.name;
                l.bindPopup(buildPopup(name));
                l.bindTooltip(name, { permanent: true, direction: 'center', className: 'label', opacity: 0 });
            }
        }).addTo(map);

        map.fitBounds(geoLayer.getBounds());

        function runFilters() {
            const asm = document.getElementById('asmSelect').value;
            const search = document.getElementById('sectorInput').value.toUpperCase();
            
            let ppT = 0, ptmT = 0, indT = 0, count = 0;
            const bounds = L.latLngBounds();
            let hasVisible = false;

            geoLayer.eachLayer(l => {
                const sec = l.feature.properties.name;
                const d = excelData[sec];
                const matchesAsm = (asm === 'all' || (d && d.asm === asm));
                const matchesSearch = (search === '' || sec.includes(search));

                if (matchesAsm && matchesSearch) {
                    l.setStyle({ opacity: 1, fillOpacity: 0.7, interactive: true });
                    // Fix: Ensure popup is only bound for visible sectors
                    if (!l.getPopup()) l.bindPopup(buildPopup(sec));
                    
                    if (l.getTooltip()) {
                        l.getTooltip().setOpacity(map.getZoom() < 12 ? 0 : 0.95);
                    }
                    
                    bounds.extend(l.getBounds());
                    hasVisible = true;

                    if (d) {
                        ppT += parseFloat(d.pp_txn.replace(/,/g, '')) || 0;
                        ptmT += parseFloat(d.ptm_txn.replace(/,/g, '')) || 0;
                        indT += parseFloat(d.ind_txn.replace(/,/g, '')) || 0;
                        count++;
                    }
                } else {
                    // Fix: Hide and disable interaction for filtered sectors
                    l.setStyle({ opacity: 0, fillOpacity: 0, interactive: false });
                    l.unbindPopup();
                    if (l.getTooltip()) l.getTooltip().setOpacity(0);
                }
            });

            if (hasVisible) {
                map.fitBounds(bounds, { padding: [30, 30] });
            }

            const ppMS = indT > 0 ? ((ppT / indT) * 100).toFixed(1) : "0.0";
            const ptmMS = indT > 0 ? ((ptmT / indT) * 100).toFixed(1) : "0.0";
            
            document.getElementById('sumSectors').innerText = count;
            document.getElementById('sumPPMS').innerText = ppMS + "%";
            document.getElementById('sumPPTxn').innerText = Math.round(ppT).toLocaleString();
            document.getElementById('sumIndTxn').innerText = Math.round(indT).toLocaleString();
            document.getElementById('sumPTMMS').innerText = ptmMS + "%";
        }

        map.on('zoomend', function() {
            const z = map.getZoom();
            geoLayer.eachLayer(l => {
                if (l.getTooltip()) {
                    if (z < 12) l.getTooltip().setOpacity(0);
                    else {
                        const asm = document.getElementById('asmSelect').value;
                        const search = document.getElementById('sectorInput').value.toUpperCase();
                        const sec = l.feature.properties.name;
                        const d = excelData[sec];
                        if ((asm === 'all' || (d && d.asm === asm)) && (search === '' || sec.includes(search))) {
                            l.getTooltip().setOpacity(0.95);
                        } else {
                            l.getTooltip().setOpacity(0);
                        }
                    }
                }
            });
        });

        // Init ASM Dropdown
        const asms = new Set();
        Object.values(excelData).forEach(d => { if(d.asm && d.asm !== "-") asms.add(d.asm); });
        const sel = document.getElementById('asmSelect');
        Array.from(asms).sort().forEach(a => {
            const opt = document.createElement('option');
            opt.value = a; opt.innerText = a; sel.appendChild(opt);
        });

        runFilters();

        let myMarker;
        function findMyLocation() {
            if (!navigator.geolocation) return alert("Geolocation not supported");
            navigator.geolocation.getCurrentPosition(pos => {
                const { latitude, longitude } = pos.coords;
                map.setView([latitude, longitude], 15);
                if (myMarker) map.removeLayer(myMarker);
                myMarker = L.circleMarker([latitude, longitude], { radius: 8, fillColor: '#2196f3', color: '#fff', weight: 2, fillOpacity: 0.8 }).addTo(map).bindPopup("<b>You are here</b>").openPopup();
            }, (err) => {
                alert("Location Error: Please ensure GPS is enabled and permission is granted.");
            }, { enableHighAccuracy: true, timeout: 5000 });
        }
    </script>
